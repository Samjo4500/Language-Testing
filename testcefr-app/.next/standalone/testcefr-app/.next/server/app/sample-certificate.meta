{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/sample-certificate/layout,_N_T_/sample-certificate/page,_N_T_/sample-certificate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/sample-certificate/__PAGE__",
    "/sample-certificate",
    "/_index",
    "/_head"
  ]
}