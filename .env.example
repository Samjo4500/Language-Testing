# TestCEFR Environment Variables
# Copy this file to .env.local and fill in the values

# Database — Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/database?sslmode=require"

# Authentication
JWT_SECRET="your-secret-key-min-32-chars"

# Google AI (Gemini) — for assessment evaluation & chat
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# Resend — transactional emails
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# App URL
NEXT_PUBLIC_APP_URL="https://www.testcefr.com"

# PayPal
PAYPAL_MODE="sandbox"  # "sandbox" or "live"
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"  # From PayPal developer dashboard

# ── Analytics ──

# Google Analytics 4 — client-side tracking
# Create a GA4 property at https://analytics.google.com → Admin → Create Property
# Get the Measurement ID from Admin → Data Streams → your web stream (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Ads — conversion tracking
# Get the Ads ID from Google Ads → Tools → Conversions (format: AW-XXXXXXXXXX)
NEXT_PUBLIC_GA_ADS_ID=""

# Google Analytics 4 — server-side Measurement Protocol
# Required for reliable server-side purchase tracking (bypasses ad-blockers)
# Get the API Secret from GA4 Admin → Data Streams → your web stream → Measurement Protocol API Secrets → Create
GA_API_SECRET=""

# PostHog — product analytics, session replay, feature flags
# Create a project at https://app.posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=""

# PostHog host — use the region-specific host shown in your PostHog project settings
# US: https://us.i.posthog.com  |  EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── LiveKit (Self-Hosted Video/Audio) ──

# LiveKit server URL (WebSocket) — used by the browser to connect
# Self-hosted: wss://livekit.testcefr.com:7881
# LiveKit Cloud: wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL="wss://livekit.testcefr.com:7881"

# LiveKit server API key & secret — used server-side to generate tokens and manage rooms
# Generate with: openssl rand -hex 16 (key) / openssl rand -hex 32 (secret)
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# LiveKit HTTP API URL (server-side only, not exposed to browser)
# Self-hosted: http://localhost:7880 or https://livekit.testcefr.com:7880
LIVEKIT_HTTP_URL="https://livekit.testcefr.com:7880"

# Cloudflare R2 (or S3) for recordings storage
R2_BUCKET_NAME="livekit-recordings"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
