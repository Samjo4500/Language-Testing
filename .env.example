# TestCEFR Environment Variables
# Copy this file to .env.local and fill in the values

# ── Security ──────────────────────────────────────────────

# Authentication — MUST be set in production. Minimum 32 characters.
# Generate with: openssl rand -base64 48
JWT_SECRET="your-secret-key-min-32-chars"

# Admin email — users registering with this email are auto-promoted to admin
ADMIN_EMAIL=""

# Cron secret — required for Vercel cron job endpoints (/api/cron/*)
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Cookie Secure flag — set to "true" if your deployment uses HTTPS
# (Vercel sets NODE_ENV=production which auto-enables Secure cookies)
COOKIE_SECURE="true"

# ── Database ──────────────────────────────────────────────

# Database — Neon PostgreSQL (production) or SQLite (development)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/database?sslmode=require"

# ── AI Providers ──────────────────────────────────────────

# Google AI (Gemini) — for assessment evaluation, chat, grammar check, and TTS
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# ── Email ─────────────────────────────────────────────────

# Resend — transactional emails
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ── Public App Config ─────────────────────────────────────

# App URL — used for email links, OAuth callbacks, etc.
NEXT_PUBLIC_APP_URL="https://www.testcefr.com"

# ── Payments ──────────────────────────────────────────────

# PayPal
PAYPAL_MODE="sandbox"  # "sandbox" or "live"
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
# Webhook ID — REQUIRED for webhook signature verification.
# Without this, PayPal webhooks will be rejected for security.
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"  # From PayPal developer dashboard

# ── Analytics ─────────────────────────────────────────────

# Google Analytics 4 — client-side tracking
# Create a GA4 property at https://analytics.google.com → Admin → Create Property
# Get the Measurement ID from Admin → Data Streams → your web stream (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Ads — conversion tracking
# Get the Ads ID from Google Ads → Tools → Conversions (format: AW-XXXXXXXXXX)
NEXT_PUBLIC_GA_ADS_ID=""

# Google Analytics 4 — server-side Measurement Protocol
# Required for reliable server-side purchase tracking (bypasses ad-blockers)
# Get the API Secret from GA4 Admin → Data Streams → your web stream → Measurement Protocol API Secrets → Create
GA_API_SECRET=""

# PostHog — product analytics, session replay, feature flags
# Create a project at https://app.posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=""

# PostHog host — use the region-specific host shown in your PostHog project settings
# US: https://us.i.posthog.com  |  EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── LiveKit (Video/Audio) ────────────────────────────────

# LiveKit server URL (WebSocket) — server-side only (not exposed to client bundle).
# Prefer LIVEKIT_URL over NEXT_PUBLIC_LIVEKIT_URL for security.
# LiveKit Cloud (recommended): wss://your-project.livekit.cloud
# Self-hosted: wss://livekit.testcefr.com:7881
LIVEKIT_URL="wss://your-project.livekit.cloud"

# Legacy: NEXT_PUBLIC_LIVEKIT_URL still works as fallback but is deprecated.
# The URL is now served to clients via API routes instead of the client bundle.
# NEXT_PUBLIC_LIVEKIT_URL="wss://your-project.livekit.cloud"

# LiveKit server API key & secret — used server-side to generate tokens and manage rooms
# LiveKit Cloud: Get from https://cloud.livekit.io → Project Settings → API Keys
# Self-hosted: Generate with: openssl rand -hex 16 (key) / openssl rand -hex 32 (secret)
# REQUIRED: Webhook verification will reject events without these.
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# LiveKit HTTP API URL (server-side only, not exposed to browser)
# LiveKit Cloud: https://your-project.livekit.cloud
# Self-hosted: http://localhost:7880 or https://livekit.testcefr.com:7880
LIVEKIT_HTTP_URL="https://your-project.livekit.cloud"

# ── Sandbox/Preview Mode ─────────────────────────────────

# SANDBOX_MODE — server-only env var for API auth bypass (preview/demo).
# When "true", course API routes allow unauthenticated access.
# IMPORTANT: This is a SERVER-ONLY variable (no NEXT_PUBLIC_ prefix).
# In production, sandbox mode is ALWAYS disabled regardless of this value.
SANDBOX_MODE="false"

# NEXT_PUBLIC_SANDBOX_MODE — client-side flag for UI behavior only.
# This does NOT affect server-side auth — it only controls client-side redirects.
NEXT_PUBLIC_SANDBOX_MODE="false"

# ── Storage ───────────────────────────────────────────────

# Cloudflare R2 (or S3) for recordings storage
R2_BUCKET_NAME="livekit-recordings"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
