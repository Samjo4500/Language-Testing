generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String
  plan             String    @default("free") // "free" | "premium" | "pro"
  role             String    @default("user") // "user" | "admin"
  accountType      String    @default("individual") // "individual" | "university" | "business"
  organizationName String? // Name of university/company (for B2B accounts)
  organizationId   String? // FK to Organization (for B2B users)
  isDemo           Boolean   @default(false) // true for auto-generated demo accounts
  isSuspended      Boolean   @default(false) // Admin can suspend user accounts
  emailVerified    Boolean   @default(false)
  testCredits      Int       @default(0) // number of tests remaining
  country          String? // user's country from IP at signup
  avatarUrl        String? // Profile photo URL
  phone            String? // Phone number
  gender           String? // "male" | "female" | "non-binary" | "prefer-not-to-say"
  dateOfBirth      DateTime? // Date of birth
  bio              String? // Short bio about themselves (max 500 chars)
  englishLevel     String? // Self-reported: "A1" | "A2" | "B1" | "B2" | "C1" | "C2"
  occupation       String? // Job title or "Student", "Teacher", etc.
  isProfileComplete Boolean  @default(false) // Whether user has filled in their profile
  interests        String? // JSON array: ["travel","photography","cooking","sports","music","movies","technology","art","reading","gaming"]
  isVerified       Boolean  @default(false) // Email verified + profile complete
  trustScore       Int      @default(0) // 0-100 score based on activity
  tokenVersion     Int       @default(0) // incremented on logout/password change to invalidate old tokens
  planExpiresAt    DateTime? // when the plan expires (for subscriptions)
  passwordResetAt  DateTime? // timestamp of last successful password reset (used to invalidate old reset tokens)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payments          Payment[]            @relation("UserPayments")
  assessments       Assessment[]         @relation("UserAssessments")
  certificates      Certificate[]        @relation("UserCertificates")
  apiKeys           ApiKey[]             @relation("UserApiKeys")
  emailLogs         EmailLog[]           @relation("UserEmailLogs")
  seenQuestions     SeenQuestion[]       @relation("UserSeenQuestions")
  orgMembership     OrganizationMember[] @relation("UserOrgMembership")
  courseEnrollments CourseEnrollment[]   @relation("UserCourseEnrollments")
  languageProfile  LanguageProfile?  @relation("UserLanguageProfile")
  chatMessages     ChatRoomMessage[] @relation("UserChatMessages")
  notifications    Notification[]    @relation("UserNotifications")
  moments          Moment[]         @relation("UserMoments")
  momentComments   MomentComment[]   @relation("UserMomentComments")
  momentLikes      MomentLike[]      @relation("UserMomentLikes")
  vocabProgress    UserVocabProgress[] @relation("UserVocabProgress")

  @@index([organizationId])
}

model Question {
  id             String   @id @default(cuid())
  level          String // "A1" | "A2" | "B1" | "B2" | "C1" | "C2"
  category       String // "grammar" | "vocabulary" | "reading" | "listening"
  difficultyTier Int      @default(5) // 1-10 within the level (for adaptive selection)
  variantGroup   String? // Questions that test the same concept (variants for anti-cheat)
  text           String // The question text
  options        String // JSON array of 4 options: ["opt1", "opt2", "opt3", "opt4"]
  correctIndex   Int // 0-3 index of the correct answer
  explanation    String? // Optional explanation of the correct answer
  organizationId String? // null = global pool; non-null = org-exclusive
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([level, category, isActive, organizationId])
  @@index([variantGroup])
  @@index([organizationId])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  paypalOrderId   String   @unique
  paypalCaptureId String?
  amount          Float
  currency        String   @default("USD")
  status          String   @default("pending") // "pending" | "completed" | "failed" | "refunded"
  plan            String   @default("premium")
  planType        String? // "single" | "premium" | "pro"
  testsIncluded   Int      @default(1) // how many tests this payment includes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Assessment {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("not_started") // "not_started" | "in_progress" | "completed"
  cefrLevel   String? // "A1" | "A2" | "B1" | "B2" | "C1" | "C2"
  score       Int?
  questionSet String? // JSON snapshot of question IDs selected for this assessment
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User                 @relation("UserAssessments", fields: [userId], references: [id], onDelete: Cascade)
  responses   AssessmentResponse[] @relation("AssessmentResponses")
  certificate Certificate?         @relation("AssessmentCertificate")

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  questionType String   @default("mcq") // "mcq" | "reading" | "listening" | "speaking" | "writing"
  parentItemId String? // For reading/listening: the passageId or itemId
  answer       String?
  isCorrect    Boolean?
  aiScore      Int? // For speaking/writing: AI-evaluated score (0-100)
  aiFeedback   String? // JSON: AI evaluation details
  createdAt    DateTime @default(now())

  assessment Assessment @relation("AssessmentResponses", fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([questionType, questionId])
}

model Certificate {
  id             String   @id @default(cuid())
  verificationId String   @unique // public-facing ID for QR code & verification URL
  userId         String
  assessmentId   String?  @unique // null for course completion certificates
  userName       String
  cefrLevel      String // "A1" | "A2" | "B1" | "B2" | "C1" | "C2" | "A1-A2" | "B1-B2" | "C1-C2"
  score          Int
  skillBreakdown String   @default("{}") // JSON: { reading: 80, writing: 80, listening: 60, speaking: 80, grammar: 100, vocabulary: 80 }
  type           String   @default("assessment") // "assessment" | "course_completion"
  courseName     String?  // For course_completion certificates: the course title
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User        @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment?  @relation("AssessmentCertificate", fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([issuedAt])
  @@index([type])
}

model PageView {
  id        String   @id @default(cuid())
  path      String // "/test", "/pricing", "/", etc.
  referrer  String? // where they came from
  country   String? // from IP lookup (optional)
  ip        String? // hashed IP for unique visitor counting
  userId    String? // if logged in
  userAgent String? // browser info
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique // The actual API key (e.g., "tcefr_live_xxxxx")
  name        String // Label like "Production Key", "Staging Key"
  userId      String // Who created it
  plan        String    @default("enterprise") // "enterprise" | "business" | "team"
  type        String    @default("live") // "live" | "test"
  permissions String    @default("read") // JSON array: ["read", "write", "admin"]
  rateLimit   Int       @default(1000) // Requests per hour
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation("UserApiKeys", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WhiteLabelSetting {
  id           String   @id @default(cuid())
  companyName  String   @default("TestCEFR")
  primaryColor String   @default("#8B5CF6")
  logoUrl      String?
  domain       String?
  supportEmail String?
  customCss    String?
  features     String   @default("{}") // JSON: enabled features
  isActive     Boolean  @default(false)
  plan         String   @default("enterprise") // Required plan
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String // Recipient email
  from      String // Sender email
  subject   String // Email subject
  type      String // "welcome" | "verification" | "password_reset" | "payment" | "certificate" | "assessment" | "contact_auto_reply" | "contact_notification" | "b2b_auto_reply" | "b2b_notification" | "admin_new_user" | "admin_new_payment" | "admin_certificate" | "general"
  status    String   @default("sent") // "sent" | "failed"
  isRead    Boolean  @default(false) // Whether admin has viewed this notification
  userId    String? // If email was sent to a registered user
  error     String? // Error message if failed
  createdAt DateTime @default(now())

  user User? @relation("UserEmailLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([type])
  @@index([status])
  @@index([to])
  @@index([isRead])
}

// ═══════════════════════════════════════════════════════════
//  ORGANIZATION (B2B/institution pools)
// ═══════════════════════════════════════════════════════════

model Organization {
  id                 String   @id @default(cuid())
  name               String   @unique
  slug               String   @unique
  plan               String   @default("team") // "team" | "business" | "enterprise"
  maxMembers         Int      @default(50)
  questionPoolAccess Boolean  @default(true)
  customBranding     Boolean  @default(false)
  primaryColor       String?
  logoUrl            String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members         OrganizationMember[]
  questions       Question[]
  readingPassages ReadingPassage[]
  listeningItems  ListeningItem[]
  speakingPrompts SpeakingPrompt[]
  writingPrompts  WritingPrompt[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member") // "admin" | "member" | "viewer"
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserOrgMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
//  READING PASSAGE — parent entity with sub-questions
// ═══════════════════════════════════════════════════════════

model ReadingPassage {
  id             String   @id @default(cuid())
  level          String // "A2" | "B1" | "B2" | "C1"
  title          String?
  passageText    String
  difficultyTier Int      @default(5)
  variantGroup   String?
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?     @relation(fields: [organizationId], references: [id])
  questions    ReadingQuestion[]

  @@index([level, isActive, organizationId])
  @@index([variantGroup])
  @@index([organizationId])
}

model ReadingQuestion {
  id           String   @id @default(cuid())
  passageId    String
  questionText String
  options      String // JSON array of 4 options
  correctIndex Int // 0-3
  explanation  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  passage ReadingPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@index([passageId])
}

// ═══════════════════════════════════════════════════════════
//  LISTENING ITEM — audio script with question(s)
// ═══════════════════════════════════════════════════════════

model ListeningItem {
  id             String   @id @default(cuid())
  level          String // "A2" | "B1" | "B2" | "C1"
  scriptText     String // TTS script or transcript
  audioUrl       String?
  context        String? // "You hear:" or "Listen to a conversation about..."
  difficultyTier Int      @default(5)
  variantGroup   String?
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?       @relation(fields: [organizationId], references: [id])
  questions    ListeningQuestion[]

  @@index([level, isActive, organizationId])
  @@index([variantGroup])
  @@index([organizationId])
}

model ListeningQuestion {
  id           String   @id @default(cuid())
  itemId       String
  questionText String
  options      String // JSON array of 4 options
  correctIndex Int // 0-3
  explanation  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  item ListeningItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

// ═══════════════════════════════════════════════════════════
//  SPEAKING PROMPT — AI-evaluated
// ═══════════════════════════════════════════════════════════

model SpeakingPrompt {
  id              String   @id @default(cuid())
  level           String // "A2" | "B1" | "B2" | "C1"
  promptText      String
  preparationTime Int      @default(30) // seconds
  responseTime    Int      @default(120) // seconds
  difficultyTier  Int      @default(5)
  variantGroup    String?
  organizationId  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([level, isActive, organizationId])
  @@index([variantGroup])
  @@index([organizationId])
}

// ═══════════════════════════════════════════════════════════
//  WRITING PROMPT — AI-evaluated
// ═══════════════════════════════════════════════════════════

model WritingPrompt {
  id             String   @id @default(cuid())
  level          String // "A2" | "B1" | "B2" | "C1"
  promptText     String
  minWords       Int      @default(50)
  maxWords       Int      @default(250)
  difficultyTier Int      @default(5)
  variantGroup   String?
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([level, isActive, organizationId])
  @@index([variantGroup])
  @@index([organizationId])
}

// ═══════════════════════════════════════════════════════════
//  SEEN QUESTION — anti-repeat tracking
// ═══════════════════════════════════════════════════════════

model SeenQuestion {
  id           String   @id @default(cuid())
  userId       String
  questionType String // "mcq" | "reading" | "listening" | "speaking" | "writing"
  questionId   String // Polymorphic FK to Question/ReadingPassage/ListeningItem/SpeakingPrompt/WritingPrompt.id
  assessmentId String?
  seenAt       DateTime @default(now())

  user User @relation("UserSeenQuestions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionType, questionId])
  @@index([userId, questionType])
  @@index([userId, questionType, seenAt])
  @@index([assessmentId])
}

// ═══════════════════════════════════════════════════════════
//  ENGLISH COURSES — Online learning product (separate from assessments)
// ═══════════════════════════════════════════════════════════

model Course {
  id             String   @id @default(cuid())
  slug           String   @unique // "beginner" | "intermediate" | "advanced"
  title          String // "Beginner English"
  subtitle       String // "From A1 to A2 — Build your foundation"
  level          String // "A1-A2" | "B1-B2" | "C1-C2"
  price          Float // 49 | 79 | 99
  compareAtPrice Float? // Original price for showing discount (e.g., 79 → show "was $79")
  description    String // Full marketing description
  features       String // JSON array of feature strings
  modulesCount   Int // Total modules
  lessonsCount   Int // Total lessons
  estimatedHours Int // Estimated study hours
  imageUrl       String? // Course card image
  order          Int      @default(0) // Display order
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules     CourseModule[]
  enrollments CourseEnrollment[]

  @@index([slug])
  @@index([order])
}

model CourseModule {
  id           String  @id @default(cuid())
  courseId     String
  moduleNumber Int
  title        String
  description  String // Module description
  icon         String? // Lucide icon name for the module
  order        Int     @default(0)
  isPublished  Boolean @default(true)

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@unique([courseId, moduleNumber])
  @@index([courseId])
}

model CourseLesson {
  id               String  @id @default(cuid())
  moduleId         String
  lessonNumber     Int
  title            String
  contentType      String  @default("reading") // "reading" | "listening" | "grammar" | "vocabulary" | "quiz" | "speaking"
  content          String // HTML/Markdown lesson content
  vocabulary       String? // JSON: [{word, definition, example, pronunciation}]
  quizData         String? // JSON: [{question, options:[], correctIndex, explanation}]
  audioScript      String? // TTS script for listening lessons
  videoUrl         String? // YouTube/Vimeo video URL for embedded player
  estimatedMinutes Int     @default(15)
  order            Int     @default(0)
  isPublished      Boolean @default(true)

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([moduleId, lessonNumber])
  @@index([moduleId])
}

model CourseEnrollment {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  status          String    @default("active") // "active" | "completed" | "expired" | "refunded"
  progress        Float     @default(0) // 0-100 percentage
  currentModuleId String?
  currentLessonId String?
  paymentId       String? // PayPal order ID
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  lastAccessedAt  DateTime  @default(now())
  certificateId   String? // Verification ID for completion certificate

  user           User             @relation("UserCourseEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model LessonProgress {
  id               String    @id @default(cuid())
  enrollmentId     String
  lessonId         String
  completed        Boolean   @default(false)
  quizScore        Float?
  quizPassed       Boolean   @default(false)
  timeSpentSeconds Int       @default(0)
  completedAt      DateTime?

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     CourseLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
}

// ═══════════════════════════════════════════════════════════
//  LANGUAGE PARTNER CHAT — Community feature
// ═══════════════════════════════════════════════════════════

model LanguageProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  nativeLanguage  String   // ISO 639-1 code: "en", "es", "fr", "zh", "ja", "ko", "de", "pt", "ar", "ru", "it", "hi", "tr", "nl", "sv"
  targetLanguages String   // JSON array of ISO codes: ["en","es"]
  proficiencyLevel String  @default("intermediate") // "beginner" | "intermediate" | "advanced" | "native"
  timezone        String?  // IANA timezone: "America/New_York"
  isOnline        Boolean  @default(false)
  lastSeenAt      DateTime @default(now())
  isDiscoverable  Boolean  @default(true) // Whether they appear in partner search
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User             @relation("UserLanguageProfile", fields: [userId], references: [id], onDelete: Cascade)
  sentRequests     PartnerRequest[] @relation("SentRequests")
  receivedRequests PartnerRequest[] @relation("ReceivedRequests")
  conversations1   Conversation[]   @relation("User1Conversations")
  conversations2   Conversation[]   @relation("User2Conversations")

  @@index([nativeLanguage])
  @@index([isOnline])
  @@index([isDiscoverable])
}

model PartnerRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String?  // Optional introduction message
  status     String   @default("pending") // "pending" | "accepted" | "declined" | "cancelled"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromUser LanguageProfile @relation("SentRequests", fields: [fromUserId], references: [userId], onDelete: Cascade)
  toUser   LanguageProfile @relation("ReceivedRequests", fields: [toUserId], references: [userId], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

model Conversation {
  id           String    @id @default(cuid())
  user1Id      String    // The user who initiated
  user2Id      String    // The partner
  lastMessageAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user1    LanguageProfile @relation("User1Conversations", fields: [user1Id], references: [userId], onDelete: Cascade)
  user2    LanguageProfile @relation("User2Conversations", fields: [user2Id], references: [userId], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String   // userId of the sender
  content        String   // Message text
  type           String   @default("text") // "text" | "system" | "correction"
  correctionOriginal String? // For correction type: the original text being corrected
  correctionExplanation String? // For correction type: explanation of the correction
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead])
  @@index([conversationId, isRead])
}

// ═══════════════════════════════════════════════════════════
//  GLOBAL CHATROOM — Community feature
// ═══════════════════════════════════════════════════════════

model ChatRoom {
  id          String   @id @default(cuid())
  name        String   // "Global English Chat", "Beginners Corner", etc.
  slug        String   @unique // "global", "beginners", "intermediate", etc.
  description String?  // Room description
  language    String?  // ISO 639-1 code or "multilingual"
  levelRange  String?  // "A1-A2", "B1-B2", "C1-C2", or "all"
  imageUrl    String?  // Room icon/banner
  isPublic    Boolean  @default(true)
  maxMembers  Int      @default(0) // 0 = unlimited
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ChatRoomMessage[]

  @@index([slug])
  @@index([isPublic])
}

model ChatRoomMessage {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  userName    String   // Denormalized for fast display
  userAvatar  String?  // Denormalized avatar URL
  content     String   // Message text
  type        String   @default("text") // "text" | "system" | "image"
  imageUrl    String?  // For image type messages
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation("UserChatMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([userId])
  @@index([isDeleted])
}

// ═══════════════════════════════════════════════════════════
//  USER NOTIFICATIONS — In-app notification system
// ═══════════════════════════════════════════════════════════

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // "welcome" | "assessment_complete" | "partner_request" | "partner_accepted" | "course_enrolled" | "certificate_ready" | "plan_upgrade" | "system" | "chat_message"
  title      String
  message    String
  isRead     Boolean  @default(false)
  actionUrl  String?  // URL to navigate when clicked
  createdAt  DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════
//  MOMENTS — Community social feed
// ═══════════════════════════════════════════════════════════

model Moment {
  id          String   @id @default(cuid())
  userId      String
  content     String   // Text content (max 1000 chars)
  imageUrl    String?  // Optional attached image
  audioUrl    String?  // Optional audio recording (base64 or URL)
  language    String?  // ISO code of the language this post is in
  tags        String?  // JSON array of tags: ["grammar","vocabulary","culture"]
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation("UserMoments", fields: [userId], references: [id], onDelete: Cascade)
  comments MomentComment[]
  likes    MomentLike[]

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([isDeleted])
}

model MomentComment {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  content   String   // Max 500 chars
  isCorrection Boolean @default(false)
  correctedText String? // If this is a correction comment
  createdAt DateTime @default(now())

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation("UserMomentComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([momentId, createdAt])
}

model MomentLike {
  id       String @id @default(cuid())
  momentId String
  userId   String

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation("UserMomentLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([momentId])
}

// ═══════════════════════════════════════════════════════════
//  VOCABULARY TRAINER — Spaced repetition learning
// ═══════════════════════════════════════════════════════════

model VocabWord {
  id           String   @id @default(cuid())
  word         String
  definition   String
  example      String
  pronunciation String?
  level        String   // "A1" | "A2" | "B1" | "B2" | "C1" | "C2"
  category     String   // "general" | "business" | "travel" | "academic" | "idioms" | "phrasal_verbs"
  audioUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  progress     UserVocabProgress[]

  @@unique([word, level, category])
  @@index([level, category, isActive])
  @@index([category, isActive])
}

model UserVocabProgress {
  id            String   @id @default(cuid())
  userId        String
  wordId        String
  box           Int      @default(1) // 1-5 (Leitner box system)
  nextReview    DateTime @default(now())
  correctStreak Int      @default(0)
  totalReviews  Int      @default(0)
  lastReviewed  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User       @relation("UserVocabProgress", fields: [userId], references: [id], onDelete: Cascade)
  word VocabWord  @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, nextReview])
  @@index([userId, wordId])
}
