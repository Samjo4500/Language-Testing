"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></div></div></header><main id=\"main-content\"><div class=\"min-h-screen\" style=\"background: rgb(13, 15, 28);\"><div class=\"relative overflow-hidden py-14 px-4\"><div class=\"absolute inset-0 pointer-events-none\" style=\"background: radial-gradient(60% 40% at 50% 0%, rgba(124, 58, 237, 0.18) 0%, transparent 70%);\"></div><div class=\"max-w-3xl mx-auto text-center relative z-10\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-5\" style=\"background: rgba(124, 58, 237, 0.18); border: 1px solid rgba(124, 58, 237, 0.35); color: rgb(196, 181, 253); opacity: 0; transform: translateY(-5.32015px);\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-headphones\"><path d=\"M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3\"></path></svg>Listening Comprehension</div><h1 class=\"text-3xl md:text-4xl font-extrabold text-white mb-3 leading-tight\" style=\"opacity: 0; transform: translateY(7.82404px);\">Listening Practice</h1><p class=\"text-slate-400 text-base max-w-xl mx-auto\" style=\"opacity: 0;\">Press <strong class=\"text-slate-300\">Play Passage</strong> to hear the text read aloud, then answer the comprehension questions below.</p><div class=\"flex items-center justify-center gap-6 mt-6 flex-wrap\" style=\"opacity: 0; transform: translateY(8px);\"><div class=\"text-center\"><p class=\"text-xl font-bold text-white\">1</p><p class=\"text-xs text-slate-500\">Passage</p></div><div class=\"text-center\"><p class=\"text-xl font-bold text-white\">3</p><p class=\"text-xs text-slate-500\">Questions</p></div><div class=\"text-center\"><p class=\"text-xl font-bold text-white\">B2</p><p class=\"text-xs text-slate-500\">Level</p></div></div></div></div><div class=\"max-w-3xl mx-auto px-4 pb-16 space-y-6\"><div class=\"flex items-start gap-3 rounded-xl p-4\" style=\"background: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.25); opacity: 0;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open text-cyan-400 shrink-0 mt-0.5\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg><p class=\"text-cyan-300 text-sm\"><strong>Tip:</strong> You can read the passage text while listening, or cover it and practise pure listening comprehension. Play it as many times as you need before answering.</p></div><div class=\"rounded-2xl overflow-hidden\" style=\"background: rgb(22, 25, 41); border: 1px solid rgba(255, 255, 255, 0.08); opacity: 0; transform: translateY(10.6403px);\"><div class=\"p-5 pb-4 flex items-start gap-4\"><div class=\"w-10 h-10 rounded-xl flex items-center justify-center shrink-0 text-lg font-bold\" style=\"background: rgba(124, 58, 237, 0.2); border: 1px solid rgba(124, 58, 237, 0.4); color: rgb(167, 139, 250);\">1</div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 flex-wrap mb-1\"><span class=\"text-xs font-bold px-2 py-0.5 rounded-full\" style=\"background: rgba(124, 58, 237, 0.2); border: 1px solid rgba(124, 58, 237, 0.4); color: rgb(167, 139, 250);\">B2</span><span class=\"text-white font-semibold text-sm\">Remote Work</span></div><p class=\"text-xs text-slate-400\">Listen to the passage, then answer the questions</p></div></div><div class=\"mx-5 mb-4 rounded-xl p-4\" style=\"background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.07);\"><p class=\"text-slate-300 text-sm leading-relaxed\"><span>Many </span><span>companies </span><span>now </span><span>allow </span><span>employees </span><span>to </span><span>work </span><span>from </span><span>home </span><span>permanently. </span><span>Supporters </span><span>say </span><span>remote </span><span>work </span><span>saves </span><span>commuting </span><span>time </span><span>and </span><span>reduces </span><span>office </span><span>costs </span><span>significantly. </span><span>Critics </span><span>argue </span><span>it </span><span>reduces </span><span>collaboration </span><span>and </span><span>weakens </span><span>company </span><span>culture </span><span>over </span><span>time. </span><span>A </span><span>recent </span><span>study </span><span>found </span><span>productivity </span><span>increased </span><span>by </span><span>13% </span><span>for </span><span>remote </span><span>workers </span><span>compared </span><span>to </span><span>their </span><span>office-based </span><span>counterparts. </span><span>However, </span><span>the </span><span>same </span><span>study </span><span>noted </span><span>that </span><span>remote </span><span>workers </span><span>reported </span><span>higher </span><span>levels </span><span>of </span><span>loneliness </span><span>and </span><span>reduced </span><span>opportunities </span><span>for </span><span>spontaneous </span><span>creative </span><span>collaboration. </span><span>Companies </span><span>are </span><span>now </span><span>experimenting </span><span>with </span><span>hybrid </span><span>models </span><span>that </span><span>combine </span><span>the </span><span>flexibility </span><span>of </span><span>remote </span><span>work </span><span>with </span><span>the </span><span>social </span><span>benefits </span><span>of </span><span>office </span><span>environments.</span></p></div><div class=\"px-5 mb-1\"><button class=\"w-full flex items-center justify-center gap-2.5 py-3 rounded-xl font-semibold text-sm transition-all duration-200\" style=\"background: linear-gradient(135deg, rgb(124, 58, 237), rgb(236, 72, 153)); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; color: rgb(255, 255, 255); box-shadow: rgba(124, 58, 237, 0.35) 0px 4px 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-volume2\"><path d=\"M11 4.702a.705.705 0 0 0-1.203-.498L6.413 7.587A1.4 1.4 0 0 1 5.416 8H3a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h2.416a1.4 1.4 0 0 1 .997.413l3.383 3.384A.705.705 0 0 0 11 19.298z\"></path><path d=\"M16 9a5 5 0 0 1 0 6\"></path><path d=\"M19.364 18.364a9 9 0 0 0 0-12.728\"></path></svg>Play Passage<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"white\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-play\"><polygon points=\"6 3 20 12 6 21 6 3\"></polygon></svg></button></div></div></div></div></main><footer style=\"background-color: rgb(8, 10, 20); border-top: 1px solid rgba(255, 255, 255, 0.06);\"><div class=\"container mx-auto px-4 py-12\"><div class=\"grid grid-cols-1 md:grid-cols-4 gap-8\"><div class=\"col-span-1\"><a class=\"flex items-center gap-2 mb-3 group\" href=\"/\" data-discover=\"true\"><svg width=\"30\" height=\"30\" viewBox=\"0 0 40 40\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><circle cx=\"20\" cy=\"20\" r=\"18\" fill=\"rgba(124,58,237,0.15)\" stroke=\"rgba(168,85,247,0.30)\" stroke-width=\"1\"></circle><circle cx=\"20\" cy=\"20\" r=\"14\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"3\" fill=\